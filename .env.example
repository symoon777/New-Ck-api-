# ═══════════════════════════════════════════════════
# তোমার API এর format:
# GET https://ff.api.emonaxc.com/like?key=YSXHC6&uid={UID}
#
# নিচে URL এ key already আছে, {UID} auto replace হবে
# ═══════════════════════════════════════════════════

# Like 100 API — 100 like পাঠাবে
LIKE_API_100=https://ff.api.emonaxc.com/like?key=YSXHC6&uid={UID}

# Like 200 API — 200 like পাঠাবে (যদি আলাদা endpoint থাকে)
# না থাকলে same URL দাও
LIKE_API_200=https://ff.api.emonaxc.com/like?key=YSXHC6&uid={UID}

# API Secret (তোমার API তে লাগে না তাই যেকোনো কিছু দাও)
LIKE_API_SECRET=not_needed

# Admin Panel login token
ADMIN_TOKEN=ams_admin_2024_secret

# Environment
APP_ENV=production
